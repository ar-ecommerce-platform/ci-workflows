<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Suppress Javadoc rules for test/config classes -->
    <suppress checks="Javadoc.*" files=".*(Test|Tests|Config)\.java"/>

    <!-- Suppress visibility checks on Spring or DI annotations -->
    <suppress checks="VisibilityModifier" files=".*" lines=".*@Autowired.*"/>
    <suppress checks="VisibilityModifier" files=".*" lines=".*@Value.*"/>
    <suppress checks="VisibilityModifier" files=".*" lines=".*@Inject.*"/>

    <!-- Optionally ignore generated code or Lombok-annotated files -->
    <suppress files=".*(Generated|Lombok).*\.java" checks=".*"/>
</suppressions>
