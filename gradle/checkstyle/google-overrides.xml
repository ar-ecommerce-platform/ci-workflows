<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>

    <!-- === Import the base Google config (local file) === -->
    <module name="ConfigurationLoader">
        <property name="file" value="gradle/checkstyle/google_checks.xml"/>
    </module>

    <!-- Base Google style -->
    <module name="TreeWalker">
        <!-- Relax field visibility rules for Spring beans -->
        <module name="VisibilityModifier">
            <property name="scope" value="protected"/>
            <property name="allowPublicFinalFields" value="true"/>
            <property name="allowPublicImmutableFields" value="true"/>
            <property name="allowProtectedFinalFields" value="true"/>
            <property name="ignoreFieldNames" value="serialVersionUID,logger,LOGGER"/>
        </module>

        <!-- Ignore magic numbers for -1, 0, 1 -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1,0,1"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>
    </module>

    <!-- Suppressions file -->
    <module name="SuppressionFilter">
        <property name="file" value="checkstyle-suppressions.xml"/>
    </module>
</module>
