<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>

    <!-- ============================= -->
    <!-- Conditional base configuration -->
    <!-- ============================= -->
    <!-- Try loading local google_checks.xml (for dev),
         otherwise fall back to the remote Google config -->
    <property name="basedir" value="${basedir}"/>
    <property name="config_loc" value="${basedir}/gradle/checkstyle/google_checks.xml"/>
    <property name="fallback_config" value="https://raw.githubusercontent.com/checkstyle/checkstyle/master/src/main/resources/google_checks.xml"/>

    <!-- Import base Google rules -->
    <module name="ImportControl">
        <property name="file" value="${config_loc}"/>
    </module>

    <!-- ======== Overrides for Spring / modern Java ======== -->
    <module name="TreeWalker">

        <!-- Visibility rules (relaxed for Spring DI) -->
        <module name="VisibilityModifier">
            <property name="scope" value="protected"/>
            <property name="allowPublicFinalFields" value="true"/>
            <property name="allowPublicImmutableFields" value="true"/>
            <property name="allowProtectedFinalFields" value="true"/>
            <property name="ignoreFieldNames" value="serialVersionUID,logger,LOGGER"/>
        </module>

        <!-- Relax magic number and hashcode -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1,0,1"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>

        <!-- Optional: consistent braces and spacing -->
        <module name="NeedBraces"/>
        <module name="EmptyLineSeparator"/>
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>
        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>
    </module>

    <!-- Global suppressions (tests, Lombok, generated code) -->
    <module name="SuppressionFilter">
        <property name="file" value="${basedir}/gradle/checkstyle/checkstyle-suppressions.xml"/>
    </module>
</module>
