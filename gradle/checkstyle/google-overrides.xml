<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <!-- Include the base Google config -->
    <module name="ImportControl">
        <property name="file" value="https://raw.githubusercontent.com/checkstyle/checkstyle/master/src/main/resources/google_checks.xml"/>
    </module>

    <!-- ==== Global Overrides ==== -->
    <!-- ==== TreeWalker rules ==== -->
    <module name="TreeWalker">

        <!-- Allow Spring DI visibility patterns -->
        <module name="VisibilityModifier">
            <property name="scope" value="protected"/>
            <property name="allowPublicFinalFields" value="true"/>
            <property name="allowPublicImmutableFields" value="true"/>
            <property name="allowProtectedFinalFields" value="true"/>
            <property name="ignoreFieldNames" value="serialVersionUID,logger,LOGGER"/>
        </module>

        <!-- Disable noisy checks that are redundant or problematic in Spring apps -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1,0,1"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>

        <!-- Optional: keep NeedBraces for consistency -->
        <module name="NeedBraces"/>

        <!-- Optional: ensure empty lines between methods/classes -->
        <module name="EmptyLineSeparator"/>

        <!-- Optional: good brace style consistency -->
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>
        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>
    </module>

    <!-- Load suppressions file for test and Javadoc exemptions -->
    <module name="SuppressionFilter">
        <property name="file" value="https://raw.githubusercontent.com/ar-ecommerce-platform/ci-workflows/main/gradle/checkstyle/checkstyle-suppressions.xml"/>
    </module>
</module>
